[Unit]
Description=Claude Code Marketplace site
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/claude-code
Environment=NODE_ENV=production
Environment=HOST=127.0.0.1
Environment=PORT=3000
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/env node /var/www/claude-code/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
